// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  phone     String  @unique
  name      String
  title     String
  company   String
  role      String  // "owner", "vendor", "broker", "investor"
  assetTypes String[] // ["multifamily", "office", etc]
  markets   String[] // ["NYC", "NJ", etc]
  verified  Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  channels  Channel[]
  messagesAsSender Message[]
  matchesAsUser1 Match[] @relation("User1Matches")
  matchesAsUser2 Match[] @relation("User2Matches")
  feedbackAsSender Feedback[] @relation("SenderFeedback")
  feedbackAsReceiver Feedback[] @relation("ReceiverFeedback")
}

// Channel model
model Channel {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users     User[]
  messages  Message[]
}

// Message model
// sender relation is optional until auth is added; senderName carries the
// display name for messages sent by unauthenticated members
model Message {
  id         Int      @id @default(autoincrement())
  content    String
  senderName String
  sender     User?    @relation(fields: [senderId], references: [id])
  senderId   Int?
  channel    Channel  @relation(fields: [channelId], references: [id])
  channelId  Int
  createdAt  DateTime @default(now())

  @@index([channelId])
  @@index([senderId])
}

// Match model
model Match {
  id        Int     @id @default(autoincrement())
  user1     User    @relation("User1Matches", fields: [user1Id], references: [id])
  user1Id   Int
  user2     User    @relation("User2Matches", fields: [user2Id], references: [id])
  user2Id   Int
  status    String  // "pending", "approved", "met", "completed"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  feedback  Feedback[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

// Feedback model
model Feedback {
  id        Int     @id @default(autoincrement())
  match     Match   @relation(fields: [matchId], references: [id])
  matchId   Int
  sender    User    @relation("SenderFeedback", fields: [senderId], references: [id])
  senderId  Int
  receiver  User    @relation("ReceiverFeedback", fields: [receiverId], references: [id])
  receiverId Int
  valuable  String  // "yes", "somewhat", "no"
  followup  String  // "yes", "maybe", "no"
  improvements String?
  createdAt DateTime @default(now())

  @@index([matchId])
  @@index([senderId])
  @@index([receiverId])
}

// Event model
model Event {
  id        Int     @id @default(autoincrement())
  title     String
  description String?
  startDate DateTime
  endDate   DateTime
  location  String?
  capacity  Int?
  price     Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  registrations EventRegistration[]
}

// Event Registration model
model EventRegistration {
  id        Int     @id @default(autoincrement())
  event     Event   @relation(fields: [eventId], references: [id])
  eventId   Int
  userEmail String
  status    String  // "registered", "attended", "cancelled"
  createdAt DateTime @default(now())

  @@unique([eventId, userEmail])
}
